{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "forgejo": {
      "type": "local",
      "command": [
        "docker", "run", "-i", "--rm",
        "-e", "FORGEJO_URL=http://your-forgejo-host:3000",
        "-e", "FORGEJO_TOKEN=your_token_here",
        "forgejo-mcp-server"
      ]
    }
  }
}
